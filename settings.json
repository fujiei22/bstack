{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"${CLAUDE_PROJECT_DIR}/hooks/branch-safety.ps1\""
          },
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"${CLAUDE_PROJECT_DIR}/hooks/file-type-guard.ps1\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_PROJECT_DIR}/statusline.sh\""
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "AskUserQuestion",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git config --get:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote -v)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "mcp__mysql__mysql_query"
    ],
    "deny": [],
    "ask": []
  }
}
